class Solution {
    public int maxArea(int[] height) {
        int n=height.length;
        int maxArea=0;
        int i=0,j=n-1;
        while(i<j){

                int h=Math.min(height[i],height[j]);
                int breadth=j-i;
                int Area=h*breadth;
                maxArea=Math.max(maxArea,Area);
                if(height[i]<height[j]){
                i++;
                }
                else{
                    j--;
                }
            }
        return maxArea;
    }
}